rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidTeamCreate() {
      return request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.passcodeHash is string
        && request.resource.data.teamId.size() >= 6
        && request.resource.data.passcodeHash.size() >= 32;
    }

    match /teams/{teamId} {
      allow create: if isValidTeamCreate();
      allow get: if true;
      allow list: if false;
      allow update: if request.resource.data.passcodeHash == resource.data.passcodeHash;
      allow delete: if false;

      match /players/{playerId} {
        allow get: if true;
        allow list: if false;
        allow create, update: if request.resource.data.playerName is string;
        allow delete: if false;
      }

      match /games/{gameId} {
        allow get: if true;
        allow list: if false;
        allow create, update: if true;
        allow delete: if false;

        match /substitutions/{substitutionId} {
          allow get: if true;
          allow list: if false;
          allow create: if request.resource.data.minute is int;
          allow update, delete: if false;
        }
      }

      match /stats/{playerId} {
        allow get: if true;
        allow list: if false;
        allow create, update: if true;
        allow delete: if false;
      }
    }
  }
}
